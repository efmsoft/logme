{
  "control": {
    "enable": true,
    "port": 1234,
    "interface": "loopback"
  },

  "flags": {
    "default": {
      "Timestamp": "local", // "none" | "local" | "tz" | "utc". default: "local"
      "Signature": true, // true | false. default: "true"
      "Location": "none", // none | short | full
      "Method": true, // true | false. default: "true"
      "Eol": true, // true | false. default: "true"
      "ErrorPrefix": true, // true | false. default: "true"
      "Duration": false, // true | false. default: "false"
      "ThreadID": false, // true | false. default: "false"
      "ProcessID": false, // true | false. default: "false"
      "Channel": false, // true | false. default: "false"
      "Highlight": true, // true | false. default: "true"
      "Console": "cout", // "cout" | "warncerr" | "errcerr" | "cerrcerr" | "cerr". defaulf: "cout"
      "DisableLink": false // true | false. default: "false"
    },
    "internal": {
      "Inherit": "default",
      "DisableLink": false
    }
  },

  "channels": [
    {
      "name": "",
      "level": "info",
      "flags": "default",
      "backends": [
        {
          "type": "ConsoleBackend",
          "build": "any", // "none" | "any" | "debug" | "release"
          "async": false, // true | false. default: false
          "queue-record-limit": 8192, // default: 8192
          "queue-byte-limit": "4Mb", // integer bytes or string size. default: "4Mb"
          "overflow-policy": "block" // "block" | "drop-new" | "drop-oldest" | "sync-fallback"
        },
        {
          "type": "DebugBackend",
          "platform": "windows", // "none" | "any" | "windows" | "linux"
          "build": "debug"
        },
        {
          "type": "FileBackend",
          "append": true,
          "file": "logs/app.log",
          "max-size": "100Mb",
          "on-size-limit": "rotate", // "truncate" | "rotate". default: "truncate"
          "rotation": "daily", // "none" | "hourly" | "daily" | "weekly" | "monthly"
          "archive": "logs/archive/app.{date}.{index}.log", // required for on-size-limit="rotate"
          "compression": "gz", // "none" | "gz". requires USE_ZLIB for actual gzip output
          "retention": {
            "max-files": 14, // legacy alias: "max-parts"
            "max-age": "30d",
            "max-total-size": "2Gb",
            "clean-on-start": true
          }
        }
      ]
    },
    {
      "name": "logme",
      "level": "info",
      "flags": "internal",
      "link": "", // Link to default channel
      "build": "none" // Disable internal debug channel
    }
  ]
}